# Runtime / deployment environment variables.
# Application settings (scan intervals, log cleanup, TCP ports) live in the
# database `settings` table — not here.
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
# `.env` is gitignored; never commit secrets.

# Optional — defaults to sqlite:///./network_monitor.db
# DATABASE_URL=sqlite:///./network_monitor.db

# Optional — comma-separated list of allowed origins for CORS.
# Local LAN ranges (192.168.*, 10.*, 172.16-31.*) are already allowed by regex.
# CORS_ORIGINS=http://localhost:5173,http://192.168.1.10:8000

# Bearer-token auth.
# Frontend must set localStorage.nm_api_token to the same value or all
# /api/* and /ws requests return 401. Leave empty to disable auth.
# Generate a strong random value (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`).
API_TOKEN=

# Run `alembic upgrade head` automatically on startup.
# AUTO_MIGRATE=1
